{
    "format_version": "1.10.0",
    "minecraft:client_entity": {
        "description": {
            "identifier": "murder_mystery:npc",
            "render_controllers": ["controller.render.custom_npc"],
            "materials": { "default": "entity_alphatest" },
            "textures": {
                "skin_0": "textures/entity/npc/0",
                "skin_1": "textures/entity/npc/1"
            },
            "geometry": {
                "default": "geometry.murder_mystery_npc.default",
                "slim": "geometry.murder_mystery_npc.slim"
            },
            "spawn_egg": { "base_color": "#ffffff", "overlay_color": "#000000" },
            "scripts": {
                "scale": "0.9375",
                "pre_animation": [
                    "variable.geometry = query.property('murder_mystery:geometry') == 'slim' ? 1 : 0;",
                    "variable.skin = query.property('murder_mystery:skin');",
                    "variable.tcos0 = (Math.cos(query.modified_distance_moved * 38.17) * query.modified_move_speed / variable.gliding_speed_value) * 57.3;"
                ],
                "animate": ["bob", "look_at_target_default", "controller_move"]
            },
            "animations": {
                "bob": "animation.player.bob",
                "look_at_target_default": "animation.humanoid.look_at_target.default",
                "move": "animation.humanoid.move",

                "controller_move": "controller.animation.humanoid.move"
            },
            "enable_attachables": true
        }
    }
}
